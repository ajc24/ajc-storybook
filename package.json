{
  "name": "ajc-storybook",
  "version": "1.0.0",
  "description": "Easy to import and re-use Storybook configuration for React projects.",
  "main": "build/index.js",
  "scripts": {
    "build": "babel src --out-dir build",
    "test": "npm run test-unit-coverage",
    "test-unit": "jest --config=./tests/jest-config/unit.config.js",
    "test-unit-coverage": "npm run test-unit -- --collectCoverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajc24/ajc-storybook.git"
  },
  "author": "Anthony Cox",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/ajc24/ajc-storybook/issues"
  },
  "homepage": "https://github.com/ajc24/ajc-storybook#readme",
  "dependencies": {
    "@storybook/addon-a11y": "^6.5.3",
    "@storybook/addon-docs": "^6.5.3",
    "@storybook/react": "^6.5.3"
  },
  "devDependencies": {
    "ajc-babel-config": "github:ajc24/ajc-babel-config",
    "ajc-jest-react-testing-library": "github:ajc24/ajc-jest-react-testing-library",
    "react": "^18.1.0",
    "react-dom": "^18.1.0"
  }
